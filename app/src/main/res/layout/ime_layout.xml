<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ime_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <FrameLayout
            android:id="@+id/ime_toggle_panel"
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_backspace"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/ime_toggle_panel">

            <ImageView
                android:id="@+id/ime_toggle_panel_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_expand_panel"
                android:scaleType="centerInside"
                android:tint="@color/ime_icon_tint" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp">

            <ImageView
                android:id="@+id/ime_space"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_space"
                android:scaleType="centerInside"
                android:tint="@color/ime_icon_tint"
                android:background="@drawable/bg_backspace"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp"
                android:contentDescription="Space"/>

            <FrameLayout
                android:id="@+id/ime_record"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_backspace"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Record">

                <ImageView
                    android:id="@+id/ime_record_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:scaleType="centerInside"
                    android:tint="@color/colorPrimary" />

                <ProgressBar
                    android:id="@+id/ime_record_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/ime_enter"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_enter"
            android:scaleType="centerInside"
            android:tint="@color/ime_icon_tint"
            android:background="@drawable/bg_backspace"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Enter"/>

        <TextView
            android:id="@+id/ime_backspace"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:text="⌫"
            android:textSize="24sp"
            android:textColor="@color/ime_key_text"
            android:background="@drawable/bg_backspace"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Backspace"/>
    </LinearLayout>

    <!-- Expanded panel: hidden by default, shown when toggle is pressed -->
    <LinearLayout
        android:id="@+id/expanded_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <!-- Horizontal tab strip at the top -->
        <LinearLayout
            android:id="@+id/tab_strip"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/tab_keyboard"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_keyboard_tab"
                android:scaleType="centerInside"
                android:tint="@color/ime_icon_tint"
                android:background="@drawable/bg_tab_selected"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/tab_keyboard" />

            <ImageView
                android:id="@+id/tab_history"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_history"
                android:scaleType="centerInside"
                android:tint="@color/ime_icon_tint"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/tab_history" />

            <ImageView
                android:id="@+id/tab_settings"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_settings_tab"
                android:scaleType="centerInside"
                android:tint="@color/ime_icon_tint"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/tab_settings" />
        </LinearLayout>

        <!-- Content area: stacked tab contents; only one visible at a time -->
        <FrameLayout
            android:id="@+id/panel_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Keyboard panel (shown by default) -->
            <dev.surma.parakeeb.SoftKeyboardView
                android:id="@+id/panel_keyboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- History panel (hidden by default) -->
            <FrameLayout
                android:id="@+id/panel_history"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <ListView
                    android:id="@+id/history_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="6dp"
                    android:clipToPadding="false"
                    android:scrollbarStyle="outsideOverlay" />

                <TextView
                    android:id="@+id/history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/history_empty"
                    android:textSize="13sp"
                    android:textColor="@color/ime_text_hint"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Settings panel (hidden by default) -->
            <ScrollView
                android:id="@+id/panel_settings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Auto-rewrite toggle -->
                    <include layout="@layout/setting_toggle"
                        android:id="@+id/setting_auto_rewrite_row" />

                    <!-- Paste mode toggle -->
                    <include layout="@layout/setting_toggle"
                        android:id="@+id/setting_paste_mode_row" />

                    <!-- Auto-record toggle -->
                    <include layout="@layout/setting_toggle"
                        android:id="@+id/setting_auto_record_row" />

                    <!-- Pause audio toggle -->
                    <include layout="@layout/setting_toggle"
                        android:id="@+id/setting_pause_audio_row" />

                    <!-- Select transcription toggle -->
                    <include layout="@layout/setting_toggle"
                        android:id="@+id/setting_select_transcription_row" />

                    <!-- LLM section header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_llm"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/ime_key_text"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp" />

                    <!-- LLM Base URL -->
                    <include layout="@layout/setting_text"
                        android:id="@+id/setting_llm_base_url_row" />

                    <!-- LLM Model -->
                    <include layout="@layout/setting_text"
                        android:id="@+id/setting_llm_model_row" />

                    <!-- LLM API Key -->
                    <include layout="@layout/setting_text"
                        android:id="@+id/setting_llm_api_key_row" />

                    <!-- LLM System Prompt -->
                    <include layout="@layout/setting_text"
                        android:id="@+id/setting_llm_system_prompt_row" />

                    <!-- LLM Test Connection button -->
                    <TextView
                        android:id="@+id/btn_llm_test"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_llm_test"
                        android:textSize="13sp"
                        android:textColor="@color/ime_key_text"
                        android:background="@drawable/bg_backspace"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </ScrollView>

        </FrameLayout>
    </LinearLayout>

</LinearLayout>
